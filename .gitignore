# Ignore original large SQL dump and all raw SQL dumps recursively
*.sql
*.sql.gz

# Local credential specification file (sensitive)
server_spec.md

# Ignore system junk
.DS_Store
Thumbs.db

# Bitrix ignore rules
/upload/
/bitrix/cache/
/bitrix/managed_cache/
/bitrix/stack_cache/
/bitrix/updates/
/bitrix/tmp/
/bitrix/backup/
/bitrix/vendor/
/bitrix/wizards/
/bitrix/html_pages/
/logs/
/test/

# Bitrix configuration files containing credentials (do not commit to git)
/bitrix/php_interface/dbconn.php
/bitrix/php_interface/after_connect.php
/bitrix/php_interface/after_connect_d7.php
/bitrix/.settings.php
/bitrix/.settings_extra.php
/bitrix/admin/.htaccess

# Other files
/*.log
/*.tar.gz
/*.zip
